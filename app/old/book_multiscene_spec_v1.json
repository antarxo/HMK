{
  "scene": "book_multiscene",
  "version": "v1",
  "purpose": "Ενιαία πολυσκηνή για το ηλεκτρονικό βιβλίο. Σταθερό μέγιστο ύψος: ράβδος + 3 γραφήματα.",
  "layoutRules": {
    "allowedLayouts": [
      "rod_only",
      "rod_1graph",
      "rod_2graphs",
      "rod_3graphs"
    ],
    "maxGraphsVisible": 3,
    "maxHeightRule": "Το πλαίσιο δεν ξεπερνά ποτέ το ύψος ράβδου + 3 γραφημάτων.",
    "baseFrameWidth": 340
  },
  "graphOptions": [
    "V",
    "q",
    "i",
    "E",
    "B"
  ],
  "layerOptions": [
    "rod",
    "charges",
    "currentArrow",
    "electronMotion",
    "eFieldLines",
    "bFieldLines",
    "linearPropagation"
  ],
  "timePresets": {
    "snapshots": [
      "t0",
      "tT4",
      "tT2",
      "t3T4",
      "tT"
    ],
    "intervals": [
      "q1",
      "q2",
      "q3",
      "q4"
    ]
  },
  "controls": {
    "modes": {
      "basic": {
        "description": "Μόνο έναρξη, παύση, reset.",
        "controls": [
          "play",
          "pause",
          "reset"
        ]
      },
      "guided": {
        "description": "Πάντα play, pause, reset και επιπλέον μόνο όσα επιτρέπονται από το βιβλίο.",
        "baseControls": [
          "play",
          "pause",
          "reset"
        ],
        "extraControlsAllowed": [
          "stepFwd",
          "stepBack",
          "toggleCurrent",
          "toggleCharges",
          "toggleE",
          "toggleB",
          "toggleLinear",
          "toggleGraphV",
          "toggleGraphQ",
          "toggleGraphI",
          "toggleGraphE",
          "toggleGraphB"
        ]
      }
    }
  },
  "requiredFields": [
    "type",
    "id",
    "title",
    "caption",
    "placement",
    "frameWidth",
    "wrapTight",
    "simulationSrc",
    "scene",
    "layout",
    "graphs",
    "layers",
    "timePreset",
    "controlsMode"
  ],
  "optionalFields": [
    "allowedControls",
    "status"
  ],
  "validationRules": [
    "Το scene πρέπει να είναι book_multiscene.",
    "Το frameWidth για το βιβλίο είναι 340.",
    "Το graphs επιτρέπεται να περιέχει 0 έως 3 στοιχεία.",
    "Το layout πρέπει να ταιριάζει με το πλήθος των γραφημάτων.",
    "Στο controlsMode=basic επιτρέπονται μόνο play/pause/reset.",
    "Στο controlsMode=guided το allowedControls δεν αντικαθιστά τα play/pause/reset· τα συμπληρώνει."
  ],
  "exampleSceneBlock": {
    "type": "scene",
    "id": "scene_example",
    "title": "Σκηνή 1",
    "caption": "Σκηνή 1",
    "placement": "right",
    "frameWidth": 340,
    "wrapTight": true,
    "simulationSrc": "../app/em_wave_app.html",
    "scene": "book_multiscene",
    "layout": "rod_2graphs",
    "graphs": [
      "V",
      "q"
    ],
    "layers": [
      "rod",
      "charges"
    ],
    "timePreset": "t0",
    "controlsMode": "basic"
  }
}